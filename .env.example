# Customer Churn Platform Environment Variables
PROJECT_NAME=customer-churn-platform
RAW_DATA_PATH=data/raw/telco_churn.csv
PROCESSED_DATA_PATH=data/processed/churn_features.parquet
MODEL_PATH=models/churn_model.joblib
METRICS_PATH=reports/training_metrics.json

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_ALLOW_FILE_STORE=true
MLFLOW_EXPERIMENT_NAME=telco_churn_xgboost

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CUSTOMER_EVENTS=customer-events
KAFKA_PRODUCER_DELAY=0.5

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=churn_platform
MONGO_COLLECTION=churn_predictions

# FastAPI
API_HOST=127.0.0.1
API_PORT=8000
API_PREDICT_URL=http://127.0.0.1:8000/predict
API_REQUEST_TIMEOUT=30
